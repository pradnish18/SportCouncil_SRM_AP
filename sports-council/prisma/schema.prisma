// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}



model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      String   @default("CLUB_REP")
  clubId    String?  // If role is CLUB_REP, linked to a specific club
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CouncilMember {
  id        String     @id @default(cuid())
  name      String
  title     String
  photoUrl  String?
  tier      String
  order     Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Club {
  id            String   @id @default(cuid())
  name          String   @unique
  description   String?
  logoUrl       String?
  bgImageUrl    String?
  convenorName      String?
  convenorRole      String?
  convenorDetails   String?
  coConvenorName    String?
  coConvenorRole    String?
  coConvenorDetails String?
  achievementsList  String?  // JSON stringified array of achievements
  order             Int      @default(0)
  players       Player[]
  gallery       ClubImage[]
  events        Event[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Player {
  id        String   @id @default(cuid())
  name      String
  photoUrl  String?
  club      Club     @relation(fields: [clubId], references: [id])
  clubId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClubImage {
  id        String   @id @default(cuid())
  url       String
  club      Club     @relation(fields: [clubId], references: [id])
  clubId    String
  createdAt DateTime @default(now())
}

model Event {
  id            String     @id @default(cuid())
  title         String
  sport         String
  category      String?    // e.g., "Inter-University", "Hostel vs Hostel"
  venue         String
  date          DateTime
  time          String?
  description   String?
  stage         String @default("PLANNED")
  
  // For LIVE stage
  team1         String?
  team2         String?
  score1        String?
  score2        String?
  liveUpdates   String?
  
  // For PAST stage
  winner1st     String?
  winner2nd     String?
  matchDetails  String?
  
  club          Club?      @relation(fields: [clubId], references: [id])
  clubId        String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Achievement {
  id          String              @id @default(cuid())
  title       String
  description String?
  photoUrl    String?
  date        DateTime
  sport       String
  category    String @default("TROPHY")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model News {
  id        String   @id @default(cuid())
  headline  String
  imageUrl  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Stats {
  id           String @id @default("global-stats")
  totalTeams   Int    @default(0)
  totalMembers Int    @default(0)
}
